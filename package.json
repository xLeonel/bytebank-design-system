{
  "name": "@xleonel/bytebank-design-system",
  "version": "1.11.0",
  "description": "Design System Web Components com Lit, Vite e TypeScript",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/bytebank-wc.umd.js",
  "module": "dist/bytebank-wc.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/bytebank-wc.es.js",
      "require": "./dist/bytebank-wc.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./assets/*": "./dist/assets/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "prepare": "npm run build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "check": "tsc -p tsconfig.json",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.7",
    "@semantic-release/commit-analyzer": "^9.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^8.0.0",
    "@semantic-release/npm": "^8.0.0",
    "@semantic-release/release-notes-generator": "^10.0.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/web-components-vite": "^8.6.18",
    "autoprefixer": "^10.5.0",
    "lit": "^3.0.0",
    "postcss": "^8.5.15",
    "semantic-release": "^18.0.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^5.0.0"
  }
}
